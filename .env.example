# IMAP для кодов подтверждения (Mail.ru, Yandex, Gmail и т.д.)
IMAP_HOST=imap.mail.ru
IMAP_PORT=993
IMAP_USER=your@mail.ru
IMAP_PASSWORD=app_password_here
IMAP_FOLDER=INBOX

# Playwright: headless=false чтобы видеть браузер при отладке
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=60000

# База данных
DATABASE_PATH=data/catalog_agent.db

# Секрет для сессий (опционально)
SECRET_KEY=change-me-in-production
