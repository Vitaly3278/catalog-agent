# --- Режим работы ---
# true  = 10 локальных HTML-форм (file://), без реальных каталогов и без IMAP
# false = реальные URL из registry.py + коды из почты
DEMO_MODE=true
APP_BASE_URL=http://127.0.0.1:8000

# --- IMAP (нужен при DEMO_MODE=false) ---
IMAP_HOST=imap.mail.ru
IMAP_PORT=993
IMAP_USER=your@mail.ru
IMAP_PASSWORD=app_password_here
IMAP_FOLDER=INBOX

# --- Playwright ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=60000

# --- База данных ---
DATABASE_PATH=data/catalog_agent.db

SECRET_KEY=change-me-in-production
